# Element OAuth Configuration
# These are needed once for calendar integration to work.
#
# Google: https://console.cloud.google.com/apis/credentials
#   1. Create project → OAuth consent screen → External → Add test user (your email)
#   2. Credentials → Create OAuth Client ID → Desktop app
#   3. Copy the client ID below
#
# Microsoft: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
#   1. New registration → Name: Element → Personal accounts
#   2. Authentication → Add platform → Mobile/Desktop → http://localhost
#   3. Copy Application (client) ID below

GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
